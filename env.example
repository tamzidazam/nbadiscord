# Copy this file to .env and fill in your values
# !! Never commit .env to GitHub !!

DISCORD_TOKEN=your-discord-bot-token-here
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}   # paste full JSON on one line
SPREADSHEET_ID=your-google-sheet-id-here
SHEET_NAME=Sheet1

# Column numbers in your sheet (1 = column A, 2 = column B, etc.)
COL_STUDENT_ID=1
COL_NAME=2

# Exact name of the Discord role to assign on verification
VERIFIED_ROLE_NAME=Verified
